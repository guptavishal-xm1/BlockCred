# Database
BLOCKCRED_DB_NAME=blockcred
BLOCKCRED_DB_USER=blockcred
BLOCKCRED_DB_PASSWORD=blockcred

# Legacy header auth (set false for JWT-only pilot)
BLOCKCRED_LEGACY_HEADER_AUTH=false
BLOCKCRED_ADMIN_TOKEN=
BLOCKCRED_ISSUER_TOKEN_ENABLED=false
BLOCKCRED_ISSUER_TOKEN=

# JWT auth
BLOCKCRED_JWT_ISSUER=blockcred-staff
BLOCKCRED_JWT_ACTIVE_KID=v1
BLOCKCRED_JWT_ACTIVE_KEY=change-jwt-active-key
BLOCKCRED_JWT_PREVIOUS_KID=
BLOCKCRED_JWT_PREVIOUS_KEY=
BLOCKCRED_ACCESS_TOKEN_TTL_MINUTES=15
BLOCKCRED_REFRESH_TOKEN_TTL_DAYS=7

# Seed staff users for first pilot startup
BLOCKCRED_AUTH_SEED_ENABLED=true
BLOCKCRED_AUTH_SEED_ADMIN_USERNAME=admin
BLOCKCRED_AUTH_SEED_ADMIN_EMAIL=admin@blockcred.local
BLOCKCRED_AUTH_SEED_ADMIN_DISPLAY_NAME=University Admin
BLOCKCRED_AUTH_SEED_ADMIN_PASSWORD=AdminPass#2026
BLOCKCRED_AUTH_SEED_ISSUER_USERNAME=issuer
BLOCKCRED_AUTH_SEED_ISSUER_EMAIL=issuer@blockcred.local
BLOCKCRED_AUTH_SEED_ISSUER_DISPLAY_NAME=University Issuer
BLOCKCRED_AUTH_SEED_ISSUER_PASSWORD=IssuerPass#2026

# Public verifier token signing
BLOCKCRED_PUBLIC_TOKEN_SECRET=change-public-token-secret

# Audit digest secret
BLOCKCRED_AUDIT_DIGEST_SECRET=change-audit-digest-secret

# Wallet key source
# ENV -> reads BLOCKCRED_WALLET_KEY
# FILE -> reads BLOCKCRED_WALLET_KEY_FILE path
BLOCKCRED_WALLET_KEY_SOURCE=ENV
BLOCKCRED_WALLET_KEY=change-wallet-key
BLOCKCRED_WALLET_KEY_FILE=
